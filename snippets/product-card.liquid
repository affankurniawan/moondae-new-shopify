{%- comment -%}
  MOONDAE — Product Card Snippet
  Usage: {% render 'product-card', product: product %}
  Optional: badge_text, badge_class
{%- endcomment -%}

<a href="{{ product.url }}" class="product-card">
  <div class="product-card-img">
    {%- if product.featured_image != blank -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        srcset="
          {{ product.featured_image | image_url: width: 300 }} 300w,
          {{ product.featured_image | image_url: width: 600 }} 600w
        "
        sizes="(max-width: 768px) 50vw, 25vw"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        loading="lazy"
        width="{{ product.featured_image.width }}"
        height="{{ product.featured_image.height }}"
      >
    {%- else -%}
      <div class="img-placeholder" style="display:flex;align-items:center;justify-content:center;">
        <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
      </div>
    {%- endif -%}

    {%- comment -%} Badges {%- endcomment -%}
    {%- if badge_text != blank -%}
      <span class="product-badge {{ badge_class | default: 'badge-new' }}">{{ badge_text }}</span>
    {%- elsif product.tags contains '3-in-1' -%}
      <span class="product-badge badge-3in1">3-IN-1</span>
    {%- elsif product.compare_at_price > product.price -%}
      <span class="product-badge badge-sale">SALE</span>
    {%- endif -%}

    {%- comment -%} Wishlist {%- endcomment -%}
    <button class="wishlist-btn" aria-label="Tambah ke wishlist" onclick="event.preventDefault(); event.stopPropagation(); this.classList.toggle('active');">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
    </button>

    {%- comment -%} Quick View {%- endcomment -%}
    <div class="quick-view-btn" onclick="event.preventDefault();">Quick View</div>
  </div>

  <div class="product-info">
    <p class="product-name">{{ product.title }}</p>
    <p>
      <span class="product-price">{{ product.price | money }}</span>
      {%- if product.compare_at_price > product.price -%}
        <span class="product-price-original">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </p>

    {%- comment -%} Color dots from variants {%- endcomment -%}
    {%- assign color_option = product.options_by_name['Warna'] | default: product.options_by_name['Color'] -%}
    {%- if color_option != blank -%}
      <div class="color-dots">
        {%- for value in color_option.values -%}
          {%- assign handle = value | handle -%}
          {%- case handle -%}
            {%- when 'brown' or 'moondae-brown' -%}{%- assign dot_color = '#8B7355' -%}
            {%- when 'navy' -%}{%- assign dot_color = '#232D3F' -%}
            {%- when 'beige' or 'cream' -%}{%- assign dot_color = '#CDC3BD' -%}
            {%- when 'black' -%}{%- assign dot_color = '#333333' -%}
            {%- when 'grey' or 'gray' -%}{%- assign dot_color = '#999999' -%}
            {%- when 'white' -%}{%- assign dot_color = '#F5F0EB' -%}
            {%- else -%}{%- assign dot_color = '#B2998A' -%}
          {%- endcase -%}
          <span class="color-dot" style="background:{{ dot_color }}" title="{{ value }}"></span>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</a>
