<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">

  {%- comment -%} Google Fonts {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {{ 'style.css' | asset_url | stylesheet_tag }}

  {%- if settings.favicon != blank -%}
    <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32 }}" type="image/png">
  {%- endif -%}

  {{ content_for_header }}

  <script>
    window.Moondae = {
      routes: {
        cart_url: '{{ routes.cart_url }}',
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        search_url: '{{ routes.search_url }}'
      },
      money_format: {{ shop.money_format | json }}
    };
  </script>
</head>
<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  {%- sections 'header-group' -%}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer-group' -%}

  {%- comment -%} Cart Drawer {%- endcomment -%}
  {% section 'cart-drawer' %}

  {%- comment -%} Search Overlay {%- endcomment -%}
  {% section 'search-overlay' %}

  {%- comment -%} Toast Notification {%- endcomment -%}
  <div class="toast" id="toast" aria-live="polite"></div>

  {{ 'main.js' | asset_url | script_tag }}
</body>
</html>
