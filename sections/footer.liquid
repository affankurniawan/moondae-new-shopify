{%- comment -%}
  MOONDAE — Footer
{%- endcomment -%}

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="logo">{{ settings.brand_name | default: shop.name }}</div>
        <p>{{ section.settings.footer_text }}</p>
        <p class="footer-social-label">Follow us</p>
        <div class="footer-social">
          <a href="{{ settings.social_instagram_url | default: '#' }}" target="_blank" rel="noopener" aria-label="Instagram" class="footer-social__link footer-social__link--ig">
            <span class="fs-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            </span>
            <span class="fs-name">Instagram</span>
          </a>
          <a href="{{ settings.social_tiktok_url | default: '#' }}" target="_blank" rel="noopener" aria-label="TikTok" class="footer-social__link footer-social__link--tt">
            <span class="fs-icon">
              <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.75a8.28 8.28 0 004.76 1.5V6.8a4.84 4.84 0 01-1-.11z"/></svg>
            </span>
            <span class="fs-name">TikTok</span>
          </a>
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.settings.menu.links.size > 0 -%}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <!-- Newsletter -->
      <div class="footer-newsletter">
        <p class="footer-newsletter__eyebrow">MOONBAE CIRCLE</p>
        <h3 class="footer-newsletter__heading">Join Moonbae Circle</h3>
        <p class="footer-newsletter__desc">Join a community of women who appreciate beauty in simplicity. Get early access, member discounts, and weekly styling content.</p>
        <div class="footer-newsletter__benefits">
          <span>&#10022; Early access</span>
          <span>&#10022; 10% First discount</span>
          <span>&#10022; Weekly styling tips</span>
          <span>&#10022; Exclusive events</span>
        </div>
        {%- form 'customer', id: 'footer-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="moonbae-circle,newsletter">
          <div class="footer-newsletter__form">
            <input type="email" name="contact[email]" placeholder="Your email address" required autocomplete="email">
            <button type="submit">JOIN</button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="footer-newsletter__success">Welcome to Moonbae Circle! &#10022;</p>
          {%- endif -%}
        {%- endform -%}
        <p class="footer-newsletter__disclaimer">By signing up, you agree to our privacy policy. Unsubscribe anytime.</p>
      </div>

    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} Moondae. All rights reserved.</p>
      <div class="footer-marketplaces">
        <span class="mp-label">Find us on</span>
        <a href="{{ section.settings.url_shopee | default: '#' }}" target="_blank" rel="noopener" class="mp-badge">
          <img src="{{ 'logo-shopee.png' | asset_url }}" alt="Shopee" height="18" loading="lazy">
          <span>Shopee</span>
        </a>
        <a href="{{ section.settings.url_tokopedia | default: '#' }}" target="_blank" rel="noopener" class="mp-badge">
          <img src="{{ 'logo-tokopedia.png' | asset_url }}" alt="Tokopedia" height="18" loading="lazy">
          <span>Tokopedia</span>
        </a>
        <a href="{{ section.settings.url_tiktokshop | default: '#' }}" target="_blank" rel="noopener" class="mp-badge">
          <img src="{{ 'logo-tiktok.png' | asset_url }}" alt="TikTok Shop" height="18" loading="lazy">
          <span>TikTok Shop</span>
        </a>
        <a href="{{ section.settings.url_lazada | default: '#' }}" target="_blank" rel="noopener" class="mp-badge">
          <img src="{{ 'logo-lazada.png' | asset_url }}" alt="Lazada" height="18" loading="lazy">
          <span>Lazada</span>
        </a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "settings": [
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Deskripsi brand",
      "default": "An Indonesian women's fashion bag brand with Korean minimalist aesthetics. Made with heart for women who know what they want."
    },
    {
      "type": "header",
      "content": "Link Marketplace"
    },
    {
      "type": "url",
      "id": "url_shopee",
      "label": "Shopee"
    },
    {
      "type": "url",
      "id": "url_tokopedia",
      "label": "Tokopedia"
    },
    {
      "type": "url",
      "id": "url_tiktokshop",
      "label": "TikTok Shop"
    },
    {
      "type": "url",
      "id": "url_lazada",
      "label": "Lazada"
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Kolom Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Judul kolom",
          "default": "Belanja"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "default": {
    "blocks": [
      { "type": "menu_column", "settings": { "heading": "Shop" } },
      { "type": "menu_column", "settings": { "heading": "Information" } },
      { "type": "menu_column", "settings": { "heading": "Policy" } }
    ]
  }
}
{% endschema %}
