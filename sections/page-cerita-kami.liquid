{%- comment -%}
  MOONDAE — Cerita Kami (Brand Story Page)
{%- endcomment -%}

{%- comment -%} Hero {%- endcomment -%}
<div class="story-hero">
  <div class="container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow" style="color:var(--moondae-gold); font-size:0.75rem; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:16px;">
        {{ section.settings.eyebrow }}
      </p>
    {%- endif -%}
    <h1>{{ section.settings.hero_heading }}</h1>
    <p>{{ section.settings.hero_description }}</p>
  </div>
</div>

{%- comment -%} Story Sections {%- endcomment -%}
{%- for block in section.blocks -%}
  {%- case block.type -%}

    {%- when 'story_split' -%}
      <section class="story-section" {{ block.shopify_attributes }}>
        <div class="container">
          <div class="story-split{% if block.settings.reverse %} reverse{% endif %}">
            <div class="story-split-img">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {%- endif -%}
            </div>
            <div class="story-split-text">
              {%- if block.settings.eyebrow != blank -%}
                <p class="eyebrow">{{ block.settings.eyebrow }}</p>
              {%- endif -%}
              <h2>{{ block.settings.heading }}</h2>
              <p>{{ block.settings.text }}</p>
              {%- if block.settings.text_2 != blank -%}
                <p>{{ block.settings.text_2 }}</p>
              {%- endif -%}
              {%- if block.settings.quote != blank -%}
                <blockquote style="border-left:2px solid var(--moondae-light-brown); padding-left:20px; margin-top:16px; font-style:italic; color:var(--moondae-brown);">
                  {{ block.settings.quote }}
                </blockquote>
              {%- endif -%}
            </div>
          </div>
        </div>
      </section>

    {%- when 'values' -%}
      <section class="story-section" {{ block.shopify_attributes }}>
        <div class="container" style="text-align:center;">
          {%- if block.settings.eyebrow != blank -%}
            <p class="eyebrow" style="color:var(--moondae-light-brown); font-size:0.75rem; font-weight:500; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:12px;">
              {{ block.settings.eyebrow }}
            </p>
          {%- endif -%}
          <h2 class="section-title">{{ block.settings.heading }}</h2>
          <p class="section-sub">{{ block.settings.subheading }}</p>
          <div class="story-values">
            <div class="value-card">
              <div class="value-icon">&#10022;</div>
              <h3>{{ block.settings.value_1_title }}</h3>
              <p>{{ block.settings.value_1_text }}</p>
            </div>
            <div class="value-card">
              <div class="value-icon">&#9678;</div>
              <h3>{{ block.settings.value_2_title }}</h3>
              <p>{{ block.settings.value_2_text }}</p>
            </div>
            <div class="value-card">
              <div class="value-icon">&#9671;</div>
              <h3>{{ block.settings.value_3_title }}</h3>
              <p>{{ block.settings.value_3_text }}</p>
            </div>
          </div>
        </div>
      </section>

  {%- endcase -%}
{%- endfor -%}

{%- comment -%} CTA {%- endcomment -%}
<section class="story-section" style="text-align:center;">
  <div class="container">
    <h2 class="section-title">{{ section.settings.cta_heading }}</h2>
    <p class="section-sub" style="max-width:480px; margin:0 auto 24px;">{{ section.settings.cta_text }}</p>
    <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
      {%- if section.settings.cta_button_1 != blank -%}
        <a href="{{ section.settings.cta_url_1 }}" class="btn btn-primary">{{ section.settings.cta_button_1 }}</a>
      {%- endif -%}
      {%- if section.settings.cta_button_2 != blank -%}
        <a href="{{ section.settings.cta_url_2 }}" class="btn btn-secondary">{{ section.settings.cta_button_2 }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cerita Kami",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Hero eyebrow",
      "default": "TENTANG MOONDAE"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero headline",
      "default": "Dirancang dengan hati, hadir untuk keseharianmu"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Hero deskripsi",
      "default": "Sebuah cerita tentang kesederhanaan, fungsi, dan kecintaan pada detail yang tidak terlihat tapi selalu terasa."
    },
    { "type": "header", "content": "CTA Section" },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Mulai Perjalananmu dengan Moondae"
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA deskripsi",
      "default": "Temukan tas yang bekerja sekeras kamu, tanpa mengorbankan gaya."
    },
    {
      "type": "text",
      "id": "cta_button_1",
      "label": "Tombol 1",
      "default": "Jelajahi Koleksi"
    },
    { "type": "url", "id": "cta_url_1", "label": "Link tombol 1" },
    {
      "type": "text",
      "id": "cta_button_2",
      "label": "Tombol 2",
      "default": "Gabung Moonbae Circle"
    },
    { "type": "url", "id": "cta_url_2", "label": "Link tombol 2" }
  ],
  "blocks": [
    {
      "type": "story_split",
      "name": "Story Split",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Gambar" },
        { "type": "text", "id": "eyebrow", "label": "Label atas", "default": "AWAL MULA" },
        { "type": "text", "id": "heading", "label": "Judul" },
        { "type": "textarea", "id": "text", "label": "Paragraf 1" },
        { "type": "textarea", "id": "text_2", "label": "Paragraf 2" },
        { "type": "textarea", "id": "quote", "label": "Kutipan (opsional)" },
        { "type": "checkbox", "id": "reverse", "label": "Balik posisi (gambar kanan)", "default": false }
      ]
    },
    {
      "type": "values",
      "name": "Brand Values",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Label atas", "default": "YANG KAMI PERCAYA" },
        { "type": "text", "id": "heading", "label": "Judul", "default": "Nilai-nilai Moondae" },
        { "type": "text", "id": "subheading", "label": "Subjudul", "default": "Tiga prinsip yang mendasari setiap keputusan kami — dari desain hingga pelayanan." },
        { "type": "text", "id": "value_1_title", "label": "Value 1 judul", "default": "Effortless Elegance" },
        { "type": "textarea", "id": "value_1_text", "label": "Value 1 teks", "default": "Keindahan yang tidak membutuhkan usaha berlebihan." },
        { "type": "text", "id": "value_2_title", "label": "Value 2 judul", "default": "Modern yet Understated" },
        { "type": "textarea", "id": "value_2_text", "label": "Value 2 teks", "default": "Mengikuti perkembangan tren tanpa terjebak di dalamnya." },
        { "type": "text", "id": "value_3_title", "label": "Value 3 judul", "default": "Accessible Luxury" },
        { "type": "textarea", "id": "value_3_text", "label": "Value 3 teks", "default": "Kualitas premium seharusnya bukan hak eksklusif." }
      ]
    }
  ]
}
{% endschema %}
