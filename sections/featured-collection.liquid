{%- comment -%}
  MOONDAE — Featured Collection Grid
  4-column product grid with hover effects and badges
{%- endcomment -%}

{%- assign collection = section.settings.collection -%}

<section class="featured-section">
  <div class="container">
    <div class="section-header">
      <div>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <p class="section-sub">{{ section.settings.subheading }}</p>
      </div>
      {%- if collection != blank -%}
        <a href="{{ collection.url }}" class="see-all">Lihat Semua</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: section.settings.limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          {% render 'product-card-placeholder', index: i %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Koleksi Unggulan",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Judul",
      "default": "Koleksi Unggulan"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subjudul",
      "default": "Pilihan terbaik yang paling dicintai"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Koleksi"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Jumlah produk",
      "min": 4,
      "max": 12,
      "step": 2,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Koleksi Unggulan"
    }
  ]
}
{% endschema %}
