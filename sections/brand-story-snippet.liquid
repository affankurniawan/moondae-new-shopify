{%- comment -%}
  MOONDAE — Brand Story Snippet (Split layout)
{%- endcomment -%}

<section class="brand-story-snippet">
  <div class="container">
    <div class="brand-story-grid">
      <div class="story-img">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {%- else -%}
          <div class="story-img-placeholder">
            <svg width="48" height="48" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          </div>
        {%- endif -%}
      </div>

      <div class="story-text">
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
        {%- if section.settings.text_2 != blank -%}
          <p>{{ section.settings.text_2 }}</p>
        {%- endif -%}
        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_url }}" class="btn btn-secondary">{{ section.settings.button_text }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story Snippet",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Gambar"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Label atas",
      "default": "TENTANG MOONDAE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Judul",
      "default": "Function Meets Style"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Paragraf 1",
      "default": "Moondae lahir dari keyakinan sederhana: setiap wanita berhak memiliki tas yang bekerja sekeras dirinya, tanpa mengorbankan estetika."
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Paragraf 2",
      "default": "Setiap produk Moondae dirancang dengan filosofi \"function meets style\": tidak berlebihan, selalu hadir di momen yang tepat, dan bertahan lebih lama dari tren."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Teks tombol",
      "default": "Kenali Kami Lebih Dekat"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Link tombol"
    }
  ],
  "presets": [
    {
      "name": "Brand Story Snippet"
    }
  ]
}
{% endschema %}
