{%- comment -%}
  MOONDAE — Customer Login
{%- endcomment -%}

<div class="page-hero" style="padding:40px 0;">
  <div class="container"><h1>Masuk ke Akun</h1></div>
</div>

<div class="container" style="padding-bottom:80px;">
  <div class="signup-box" style="background:white; border:1px solid var(--moondae-beige); padding:48px; max-width:440px; margin:0 auto;">
    {%- form 'customer_login', class: 'signup-form' -%}
      {{ form.errors | default_errors }}
      <div class="form-group">
        <label for="login-email">Email</label>
        <input type="email" id="login-email" name="customer[email]" placeholder="email@contoh.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label for="login-password">Password</label>
        <input type="password" id="login-password" name="customer[password]" placeholder="Password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-full" style="margin-top:12px;">Masuk</button>
      <p style="text-align:center; font-size:0.85rem; color:var(--text-secondary); margin-top:16px;">
        Belum punya akun? <a href="{{ routes.account_register_url }}" style="color:var(--moondae-brown); font-weight:600;">Daftar</a>
      </p>
    {%- endform -%}
  </div>
</div>
